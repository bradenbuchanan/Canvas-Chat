{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"importHelpers": false,
		"isolatedModules": true,
		"strictNullChecks": true,
		"lib": ["DOM", "ES2020"]
	},
	"include": ["**/*.ts"]
}
